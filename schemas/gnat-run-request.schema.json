{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boswelldigitalsolutions.com/schemas/cortex/gnat-run-request.schema.json",
  "title": "Cortex Gnat Run Request",
  "description": "Versioned request contract for bounded Cortex Gnat syntax extraction.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "request_id",
    "correlation_id",
    "operation",
    "sources",
    "requested_concurrency",
    "deadline_ms",
    "privacy_mode",
    "result_mode",
    "caller_authority_context_ref",
    "serial_fallback_allowed"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "GnatRunRequest.v1"
    },
    "request_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "operation": {
      "type": "string",
      "enum": [
        "syntax_extract"
      ]
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_ref",
          "source_path_token",
          "media_type"
        ],
        "properties": {
          "source_ref": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160
          },
          "source_path_token": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160
          },
          "media_type": {
            "type": "string",
            "enum": [
              "text/markdown",
              "text/plain",
              "application/pdf",
              "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
              "application/rtf",
              "text/rtf",
              "application/vnd.oasis.opendocument.text",
              "application/epub+zip"
            ]
          }
        }
      }
    },
    "requested_concurrency": {
      "type": "integer",
      "minimum": 1,
      "maximum": 8
    },
    "deadline_ms": {
      "type": "integer",
      "minimum": 1,
      "maximum": 86400000
    },
    "privacy_mode": {
      "type": "string",
      "enum": [
        "local_bounded"
      ]
    },
    "result_mode": {
      "type": "string",
      "enum": [
        "bounded_output",
        "artifact_reference"
      ]
    },
    "caller_authority_context_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "serial_fallback_allowed": {
      "type": "boolean"
    }
  },
  "allOf": [
    {
      "not": {
        "anyOf": [
          {
            "required": [
              "workflow_id"
            ]
          },
          {
            "required": [
              "executor"
            ]
          },
          {
            "required": [
              "raw_content_preview"
            ]
          }
        ]
      }
    }
  ]
}
