{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://boswelldigitalsolutions.com/schemas/cortex/gnat-worker-receipt.schema.json",
  "title": "Cortex Gnat Worker Receipt",
  "description": "Evidence emitted by one bounded deterministic Cortex Gnat worker attempt.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "run_id",
    "shard_id",
    "attempt_id",
    "worker_id",
    "worker_type",
    "implementation_version",
    "source_fingerprint_before",
    "source_fingerprint_after",
    "state",
    "started_at",
    "completed_at",
    "duration_ms",
    "finding_counts",
    "redaction_applied"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "GnatWorkerReceipt.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "shard_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "attempt_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "worker_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "worker_type": {
      "type": "string",
      "enum": [
        "markdown_syntax",
        "plain_text_syntax",
        "pdf_text_syntax",
        "docx_text_syntax",
        "rtf_text_syntax",
        "odt_text_syntax",
        "epub_text_syntax"
      ]
    },
    "implementation_version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "source_fingerprint_before": {
      "$ref": "#/$defs/source_fingerprint"
    },
    "source_fingerprint_after": {
      "$ref": "#/$defs/source_fingerprint"
    },
    "state": {
      "type": "string",
      "enum": [
        "complete",
        "failed",
        "cancelled",
        "timed_out",
        "stale",
        "denied"
      ]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0
    },
    "output_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "bounded_output": {
      "type": "object"
    },
    "finding_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "content_blocks",
        "sections",
        "tables_detected"
      ],
      "properties": {
        "content_blocks": {
          "type": "integer",
          "minimum": 0
        },
        "sections": {
          "type": "integer",
          "minimum": 0
        },
        "tables_detected": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "error_reason_code": {
      "type": "string",
      "enum": [
        "source_ineligible",
        "source_changed",
        "unsupported_lane",
        "schema_invalid",
        "worker_unavailable",
        "deadline_exceeded",
        "resource_limit",
        "cancelled_by_operator",
        "fa_local_unavailable",
        "output_contract_violation",
        "internal_error_redacted"
      ]
    },
    "operator_visible_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "redaction_applied": {
      "type": "boolean",
      "const": true
    }
  },
  "$defs": {
    "source_fingerprint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "digest",
        "byte_count",
        "modified_at"
      ],
      "properties": {
        "algorithm": {
          "type": "string",
          "const": "sha256"
        },
        "digest": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "byte_count": {
          "type": "integer",
          "minimum": 0
        },
        "modified_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "state": {
            "const": "complete"
          }
        },
        "required": [
          "state"
        ]
      },
      "then": {
        "oneOf": [
          {
            "required": [
              "output_ref"
            ]
          },
          {
            "required": [
              "bounded_output"
            ]
          }
        ]
      },
      "else": {
        "required": [
          "error_reason_code",
          "operator_visible_summary"
        ]
      }
    },
    {
      "not": {
        "anyOf": [
          {
            "required": [
              "raw_content_preview"
            ]
          },
          {
            "required": [
              "full_text_preview"
            ]
          },
          {
            "required": [
              "workflow_id"
            ]
          }
        ]
      }
    }
  ]
}
